# i3 config — ArchDroid
# Portado do sway (my-setup/.config/sway/config)
# QWER focus + ASDF resize + Nord colors + Nerd Font workspace icons

# ── Modifiers ──
set $mod Mod1
set $alt Mod4

# ── Nord Colors ──
set $nord0   #2E3440
set $nord1   #3B4252
set $nord2   #434C5E
set $nord3   #4C566A
set $nord4   #D8DEE9
set $nord5   #E5E9F0
set $nord6   #ECEFF4
set $nord7   #8FBCBB
set $nord8   #88C0D0
set $nord9   #81A1C1
set $nord10  #5E81AC
set $nord11  #BF616A
set $nord12  #D08770
set $nord13  #EBCB8B
set $nord14  #A3BE8C
set $nord15  #B48EAD

# ── Font ──
font pango:JetBrains Mono Medium 10

# ── General Settings ──
floating_modifier $mod normal
focus_follows_mouse yes
mouse_warping none
workspace_auto_back_and_forth yes
focus_on_window_activation smart
popup_during_fullscreen smart

# ── Gaps ──
gaps inner 4
gaps outer 2

# ── Workspace Definitions (Nerd Font icons) ──
set $ws0  "0  "
set $ws1  "1  "
set $ws2  "2  "
set $ws3  "3  "
set $ws4  "4  "
set $ws5  "5  "
set $ws6  "6  "
set $ws7  "7  "
set $ws8  "8  "
set $ws9  "9  "
set $ws10 "10 "
set $ws11 "11 "
set $ws12 "12  "
set $ws13 "1¹ "
set $ws14 "2² "
set $ws15 "3³ "
set $ws16 "4⁴ "
set $ws17 "5⁵ "
set $ws18 "6⁶ "

# ── Focus (QWER) ──
bindsym $mod+q focus left
bindsym $mod+w focus down
bindsym $mod+e focus up
bindsym $mod+r focus right

# ── Focus (Arrows) ──
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# ── Move window (Shift + QWER) ──
bindsym $mod+Shift+q move left
bindsym $mod+Shift+w move down
bindsym $mod+Shift+e move up
bindsym $mod+Shift+r move right

# ── Move window (Shift + Arrows) ──
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# ── Move to output ──
bindsym $mod+Shift+a move workspace to output right
bindsym $mod+Shift+d move workspace to output left
bindsym $mod+Shift+s move workspace to output down
bindsym $mod+Shift+w move workspace to output up

# ── Resize mode (ASDF) ──
mode "resize" {
    bindsym a resize shrink width 10 px or 10 ppt
    bindsym s resize grow height 10 px or 10 ppt
    bindsym d resize shrink height 10 px or 10 ppt
    bindsym f resize grow width 10 px or 10 ppt
    bindsym Escape mode "default"
    bindsym Return mode "default"
    bindsym $mod+c mode "default"
}
bindsym $mod+a mode "resize"

# ── Resize (u/i/o/p) ──
bindsym $mod+u resize shrink width 10 px or 10 ppt
bindsym $mod+i resize grow height 10 px or 10 ppt
bindsym $mod+o resize shrink height 10 px or 10 ppt
bindsym $mod+p resize grow width 10 px or 10 ppt

# ── Layout ──
bindsym $mod+h split horizontal
bindsym $mod+v split vertical
bindsym $mod+Shift+g split toggle

bindsym $mod+Shift+s layout stacking
bindsym $mod+Shift+t layout tabbed
bindsym $mod+Shift+d layout default
bindsym $mod+Shift+l layout toggle
bindsym $mod+Shift+v layout toggle split

bindsym $mod+t fullscreen toggle
bindsym $mod+g kill

# ── Tab / Stack (Alt) ──
bindsym $alt+z layout stacking
bindsym $alt+x layout default
bindsym $alt+c layout tabbed
bindsym $alt+v split toggle

# ── Floating ──
bindsym $mod+space focus mode_toggle
bindsym $mod+Shift+space floating toggle

# ── Sticky ──
bindsym $mod+Shift+o sticky toggle

# ── Border ──
bindsym $mod+y border toggle

# ── Scratchpad ──
bindsym $mod+minus move scratchpad
bindsym $mod+Shift+minus scratchpad show

# ── Workspace Switching (Alt+F1-F12) ──
bindsym $mod+Escape workspace $ws0
bindsym $mod+F1 workspace $ws1
bindsym $mod+F2 workspace $ws2
bindsym $mod+F3 workspace $ws3
bindsym $mod+F4 workspace $ws4
bindsym $mod+F5 workspace $ws5
bindsym $mod+F6 workspace $ws6
bindsym $mod+F7 workspace $ws7
bindsym $mod+F8 workspace $ws8
bindsym $mod+F9 workspace $ws9
bindsym $mod+F10 workspace $ws10
bindsym $mod+F11 workspace $ws11
bindsym $mod+F12 workspace $ws12
bindsym $mod+1 workspace $ws13
bindsym $mod+2 workspace $ws14
bindsym $mod+3 workspace $ws15
bindsym $mod+4 workspace $ws16
bindsym $mod+5 workspace $ws17
bindsym $mod+6 workspace $ws18

# ── Move to Workspace (Alt+Shift+F1-F12) ──
bindsym $mod+Shift+Escape move container to workspace $ws0; workspace $ws0
bindsym $mod+Shift+F1 move container to workspace $ws1; workspace $ws1
bindsym $mod+Shift+F2 move container to workspace $ws2; workspace $ws2
bindsym $mod+Shift+F3 move container to workspace $ws3; workspace $ws3
bindsym $mod+Shift+F4 move container to workspace $ws4; workspace $ws4
bindsym $mod+Shift+F5 move container to workspace $ws5; workspace $ws5
bindsym $mod+Shift+F6 move container to workspace $ws6; workspace $ws6
bindsym $mod+Shift+F7 move container to workspace $ws7; workspace $ws7
bindsym $mod+Shift+F8 move container to workspace $ws8; workspace $ws8
bindsym $mod+Shift+F9 move container to workspace $ws9; workspace $ws9
bindsym $mod+Shift+F10 move container to workspace $ws10; workspace $ws10
bindsym $mod+Shift+F11 move container to workspace $ws11; workspace $ws11
bindsym $mod+Shift+F12 move container to workspace $ws12; workspace $ws12
bindsym $mod+Shift+1 move container to workspace $ws13; workspace $ws13
bindsym $mod+Shift+2 move container to workspace $ws14; workspace $ws14
bindsym $mod+Shift+3 move container to workspace $ws15; workspace $ws15
bindsym $mod+Shift+4 move container to workspace $ws16; workspace $ws16
bindsym $mod+Shift+5 move container to workspace $ws17; workspace $ws17
bindsym $mod+Shift+6 move container to workspace $ws18; workspace $ws18

# ── Startup ──
exec_always --no-startup-id polybar main
exec_always --no-startup-id dunst
exec_always --no-startup-id picom --config /etc/xdg/picom/picom.conf -b
exec_always --no-startup-id feh --bg-fill ~/.config/wallpapers/0010.png

# ── Terminal ──
bindsym $mod+Return exec alacritty
bindsym $mod+Shift+Return exec alacritty -e tmux

# ── Rofi ──
bindsym $mod+d exec rofi -show drun -show-icons
bindsym $mod+Shift+d exec rofi -show run
bindsym $alt+F1 exec rofi -show drun -show-icons
bindsym $alt+F2 exec rofi -show run
bindsym $mod+x exec rofi -show p -modi p:rofi-powermenu
bindsym $mod+b exec rofi-bluetooth
bindsym $alt+Control+v exec rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}'

# ── Apps (Super + key) ──
bindsym $alt+Return exec alacritty
bindsym $alt+b exec brave
bindsym $alt+Shift+b exec brave --incognito
bindsym $alt+p exec brave --incognito
bindsym $alt+f exec zen-browser
bindsym $alt+Shift+f exec zen-browser --private-window
bindsym $alt+e exec nemo
bindsym $alt+o exec obsidian "obsidian://open?vault=c0daa245e54af262"
bindsym $alt+Shift+o exec obsidian "obsidian://open?vault=2bff6e0e605c8a43"
bindsym $alt+a exec gtk-launch WebApp-Claude9018.desktop
bindsym $alt+c exec gtk-launch WebApp-ChatGPT5134.desktop
bindsym $alt+w exec flatpak run com.rtosta.zapzap
bindsym $alt+g exec thunderbird
bindsym $alt+Shift+g exec beeper
bindsym $alt+z exec blueman-manager
bindsym $alt+q exec ticktick
bindsym $alt+F3 exec ticktick
bindsym $alt+F4 exec morgen
bindsym $alt+F6 exec gtk-launch WebApp-Binaural3156.desktop
bindsym $alt+F7 exec gtk-launch "Free Download Manager"
bindsym $alt+F8 exec thunderbird
bindsym $alt+F11 exec code
bindsym $alt+F12 exec gtk-launch WebApp-Chatbox2077.desktop
bindsym $alt+x exec curl "127.0.0.1:60828/selection_translate"
bindsym Control+F12 exec curl "127.0.0.1:60828/input_translate"
bindsym Control+space exec rofi -show drun -show-icons

# ── Screenshots ──
bindsym Print exec flameshot gui
bindsym Control+Print exec flameshot screen
bindsym Control+Shift+Print exec frog

# ── Lock ──
bindsym $alt+l exec i3lock

# ── Reload ──
bindsym $mod+Shift+c reload
bindsym $mod+Shift+Control+q exit

# ── Media Keys ──
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute exec pactl set-source-mute @DEFAULT_SOURCE@ toggle
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous
bindsym XF86MonBrightnessUp exec brightnessctl set +10%
bindsym XF86MonBrightnessDown exec brightnessctl set 10%-

# ── Assign: Window → Workspace ──
assign [class="(?i)firefox"] → workspace $ws1
assign [class="(?i)brave-browser"] → workspace $ws1
assign [class="(?i)zen-browser"] → workspace $ws1
assign [class="(?i)obsidian"] → workspace $ws2
assign [instance="notion.so"] → workspace $ws2
assign [instance="docs.google.com"] → workspace $ws2
assign [class="(?i)ticktick"] → workspace $ws3
assign [class="(?i)morgen"] → workspace $ws4
assign [title="(?i)agenda"] → workspace $ws4
assign [class="(?i)google-chrome"] → workspace $ws4
assign [class="(?i)beeper"] → workspace $ws5
assign [instance="web.whatsapp.com"] → workspace $ws5
assign [class="(?i)telegram"] → workspace $ws5
assign [class="(?i)zapzap"] → workspace $ws5
assign [class="(?i)thunderbird"] → workspace $ws5
assign [class="(?i)spotify"] → workspace $ws6
assign [class="(?i)stremio"] → workspace $ws6
assign [class="(?i)freetube"] → workspace $ws6
assign [class="(?i)qbittorrent"] → workspace $ws7
assign [class="(?i)fdm"] → workspace $ws7
assign [class="(?i)jdownloader"] → workspace $ws7
assign [class="(?i)nemo"] → workspace $ws9
assign [class="(?i)thunar"] → workspace $ws9
assign [class="(?i)code"] → workspace $ws11
assign [class="(?i)alacritty"] → workspace $ws10
assign [class="(?i)calibre"] → workspace $ws13
assign [class="(?i)cryptomator"] → workspace $ws13
assign [class="(?i)onlyoffice"] → workspace $ws13
assign [class="(?i)localsend"] → workspace $ws9
assign [class="MEGAsync"] → workspace $ws9

# ── Floating Rules ──
for_window [window_role="pop-up"] floating enable
for_window [window_role="task_dialog"] floating enable
for_window [class="(?i)pavucontrol"] floating enable
for_window [class="(?i)blueman"] floating enable
for_window [class="(?i)flameshot"] floating enable
for_window [class="(?i)copyq"] floating enable
for_window [class="(?i)ulauncher"] floating enable
for_window [class="(?i)xfce-polkit"] floating enable
for_window [class="(?i)kvantummanager"] floating enable
for_window [class="(?i)qt5ct"] floating enable
for_window [class="(?i)pinentry"] floating enable
for_window [class="(?i)input-remapper"] floating enable

# ── Gaps & Borders ──
for_window [class="^.*"] border pixel 1
gaps inner 8
gaps outer 4
smart_gaps on
smart_borders on

# ── Window Resize Rules ──
for_window [title="(?i)chatgpt"] resize set width 30 ppt
for_window [title="(?i)claude"] resize set width 30 ppt
for_window [title="(?i)copilot"] resize set width 30 ppt
for_window [title="(?i)gemini"] resize set width 30 ppt
for_window [instance="chatgpt.com"] resize set width 30 ppt
for_window [instance="gemini.google.com"] resize set width 30 ppt
for_window [instance="calendar.google.com"] resize set width 30 ppt
for_window [instance="vault.bitwarden.com"] resize set width 30 ppt
for_window [instance="ticktick"] resize set width 30 ppt
for_window [instance="app.raindrop.io"] resize set width 30 ppt
for_window [instance="translate.google.com"] resize set width 30 ppt
for_window [class="(?i)localsend"] resize set width 30 ppt
for_window [class="(?i)weather"] resize set width 30 ppt
for_window [class="com.github.hluk.copyq"] resize set width 30 ppt

# Polybar launched via exec_always above (not i3's bar protocol)
